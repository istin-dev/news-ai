# Environment Variables — copy this to .env and fill in values

# Django
SECRET_KEY=your-very-secret-django-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# Database (leave blank to use SQLite in development)
DATABASE_URL=

# For production PostgreSQL on Render (auto-set by Render)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Email (optional, for admin notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@tnpscaffairs.com
